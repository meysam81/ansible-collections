[Unit]
Description=Renew TLS certificates and prepare HAProxy combined PEM files
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
EnvironmentFile={{ haproxy_cert_dir }}/.env
ExecStart=/usr/local/bin/prepare-haproxy-certs.sh
StandardOutput=journal
StandardError=journal
SyslogIdentifier=haproxy-certs
ProtectSystem=strict
ReadWritePaths={{ haproxy_cert_dir }} {{ lego_cert_dir }}
PrivateTmp=true
NoNewPrivileges=true
