# {{ ansible_managed }}
http_port {{ squid_listen_address }}:{{ squid_listen_port }}

# Source ACLs
{% for src in squid_allowed_sources %}
acl wg_clients src {{ src }}
{% endfor %}

# Blocklist ACLs
{% if squid_blocked_domains_file %}
acl blocked_domains dstdomain "{{ squid_blocked_domains_file }}"
http_access deny blocked_domains
{% endif %}
{% if squid_blocked_ips_file %}
acl blocked_ips dst "{{ squid_blocked_ips_file }}"
http_access deny blocked_ips
{% endif %}

# CrowdSec external ACL
{% if squid_crowdsec_enabled %}
external_acl_type crowdsec_check ttl={{ squid_crowdsec_ttl }} %DST /usr/local/bin/crowdsec-squid-helper
acl crowdsec_blocked external crowdsec_check
http_access deny crowdsec_blocked
{% endif %}

# Extra ACLs
{% for line in squid_extra_acls %}
{{ line | regex_replace('^\s+', '') }}
{% endfor %}

# Extra rules
{% for line in squid_extra_rules %}
{{ line | regex_replace('^\s+', '') }}
{% endfor %}

# Allow tunnel clients, deny all else
http_access allow wg_clients
http_access deny all

# Logging
{% if squid_access_log_format == 'json' %}
logformat json_egress {"timestamp":"%{%Y-%m-%dT%H:%M:%S}tl","source":"%>a","method":"%rm","url":"%ru","host":"%{Host}>h","status":%>Hs,"bytes":%<st,"duration_ms":%tr,"peer":"%<a"}
access_log stdio:{{ squid_access_log_path }} json_egress
{% else %}
access_log stdio:{{ squid_access_log_path }}
{% endif %}

# Cache
{% if not squid_cache_enabled %}
maximum_object_size 0 KB
cache deny all
{% endif %}

workers {{ squid_workers }}
