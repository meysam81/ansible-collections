#!/usr/bin/env bash
# {{ ansible_managed }}
# CrowdSec external ACL helper for Squid.
# Reads destination domain/IP from stdin, queries CrowdSec LAPI,
# returns OK (allow) or ERR (block).
#
# Squid sends one line per request: "domain\n"
# Helper must reply with "OK\n" or "ERR\n"

LAPI_URL="{{ squid_crowdsec_lapi_url }}"
FAIL_MODE="{{ squid_crowdsec_fail_mode }}"

while read -r dst; do
  dst="${dst%% *}"
  [ -z "$dst" ] && { echo "OK"; continue; }

  status=$(curl -sf --max-time 2 \
    "${LAPI_URL}/v1/decisions?ip=${dst}" \
    -H "Accept: application/json" 2>/dev/null)
  curl_rc=$?

  if [ $curl_rc -ne 0 ]; then
    # LAPI unreachable
    if [ "$FAIL_MODE" = "closed" ]; then
      echo "ERR"
    else
      echo "OK"
    fi
    continue
  fi

  if [ -n "$status" ] && [ "$status" != "null" ]; then
    echo "ERR"
  else
    echo "OK"
  fi
done
