#!/usr/bin/env bash
# {{ ansible_managed }}
# Renews certs via lego, combines for HAProxy, reloads only if changed.
set -euo pipefail
umask 0077

CERT_DIR="{{ haproxy_tls_certificate_haproxy_certs_dir }}"
LEGO_DIR="{{ haproxy_tls_certificate_lego_cert_dir }}"
RELOAD_NEEDED=false
TEMP_FILES=()

cleanup() {
  for f in "${TEMP_FILES[@]}"; do
    rm -f "$f"
  done
}
trap cleanup EXIT

{% for domain in haproxy_tls_certificate_served_domains %}
# Renew {{ domain }}
lego --accept-tos --email "{{ haproxy_tls_certificate_email }}" --dns cloudflare \
  --path /etc/lego -d '{{ domain }}' renew \
  || logger -t haproxy-certs "lego renewal returned non-zero for {{ domain }}"
{% endfor %}

for crt_file in "$LEGO_DIR"/_.*\.crt; do
  [ -f "$crt_file" ] || continue
  base=$(basename "$crt_file" .crt)
  key_file="$LEGO_DIR/${base}.key"
  [ -f "$key_file" ] || continue

  # Strip leading _. to get domain name
  domain="${base#_.}"
  combined="$CERT_DIR/$domain"
  temp_cert=$(mktemp)
  TEMP_FILES+=("$temp_cert")

  cat "$crt_file" "$key_file" > "$temp_cert"
  chown haproxy:haproxy "$temp_cert"

  if ! openssl x509 -in "$temp_cert" -noout 2>/dev/null; then
    logger -t haproxy-certs "Invalid certificate for $domain, skipping"
    continue
  fi

  if ! openssl pkey -in "$key_file" -noout 2>/dev/null; then
    logger -t haproxy-certs "Invalid key for $domain, skipping"
    continue
  fi

  if [ ! -f "$combined" ] || ! cmp -s "$temp_cert" "$combined"; then
    mv "$temp_cert" "$combined"
    chmod 600 "$combined"
    RELOAD_NEEDED=true
    echo "Certificate updated for $domain"
  else
    echo "Certificate unchanged for $domain"
  fi
done

if [ "$RELOAD_NEEDED" = true ]; then
  systemctl reload haproxy
  echo "HAProxy reloaded"
fi
