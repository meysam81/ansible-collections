# {{ ansible_managed }}
[Unit]
Description=microsocks SOCKS5 proxy
After=network.target
Wants=network.target

[Service]
Type=simple
User={{ microsocks_user }}
Group={{ microsocks_user }}
ExecStart=/usr/local/bin/microsocks \
  -i {{ microsocks_listen_address }} \
  -p {{ microsocks_listen_port }}{% if microsocks_auth_user %} \
  -u {{ microsocks_auth_user }} \
  -P {{ microsocks_auth_password }}{% endif %}

Restart=on-failure
RestartSec=5

# ── Filesystem protection ─────────────────────────────────────────────
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
PrivateDevices=yes

# ── Kernel protection ─────────────────────────────────────────────────
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectControlGroups=yes
ProtectHostname=yes
ProtectClock=yes

# ── Privilege restriction ─────────────────────────────────────────────
NoNewPrivileges=yes
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
RestrictNamespaces=yes
RestrictRealtime=yes
RestrictSUIDSGID=yes
LockPersonality=yes
MemoryDenyWriteExecute=yes

# ── Syscall filtering ─────────────────────────────────────────────────
SystemCallArchitectures=native
SystemCallFilter=@system-service

# ── Resource limits ────────────────────────────────────────────────────
LimitNOFILE=65535

# ── Logging ────────────────────────────────────────────────────────────
StandardOutput=journal
StandardError=journal
SyslogIdentifier=microsocks

# ── Misc ───────────────────────────────────────────────────────────────
UMask=0077

[Install]
WantedBy=multi-user.target
