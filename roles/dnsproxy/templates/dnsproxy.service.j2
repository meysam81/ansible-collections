# {{ ansible_managed }}
#
# Hardened systemd unit for adguardteam/dnsproxy
#
# All upstreams use encrypted protocols (DoH, DoT).
# IP-based upstream URLs avoid bootstrap DNS entirely — no plaintext
# DNS query ever leaves this machine.

[Unit]
Description=dnsproxy — encrypted DNS forwarder (DoH/DoT/DoQ)
Documentation=https://github.com/AdguardTeam/dnsproxy
After=network-online.target nss-lookup.target
Wants=network-online.target
Conflicts=systemd-resolved.service dnsmasq.service named.service
StartLimitIntervalSec=60
StartLimitBurst=5

[Service]
Type=simple

ExecStart=/usr/local/bin/dnsproxy \
    --listen={{ dnsproxy_listen }} \
    --port={{ dnsproxy_port }} \
{% if dnsproxy_http3 %}
    --http3 \
{% endif %}
{% for upstream in dnsproxy_upstreams %}
    --upstream={{ upstream }} \
{% endfor %}
{% for fallback in dnsproxy_fallbacks %}
    --fallback={{ fallback }} \
{% endfor %}
{% if dnsproxy_cache %}
    --cache \
{% if dnsproxy_cache_optimistic %}
    --cache-optimistic \
{% endif %}
    --cache-size={{ dnsproxy_cache_size }} \
    --cache-min-ttl={{ dnsproxy_cache_min_ttl }} \
    --cache-max-ttl={{ dnsproxy_cache_max_ttl }} \
{% endif %}
    --upstream-mode={{ dnsproxy_upstream_mode }} \
{% if dnsproxy_pending_requests %}
    --pending-requests-enabled \
{% endif %}
{% if dnsproxy_refuse_any %}
    --refuse-any \
{% endif %}
    --timeout={{ dnsproxy_timeout }} \
    --max-go-routines={{ dnsproxy_max_goroutines }}{{ ' \\' if dnsproxy_extra_args else '' }}
{% for arg in dnsproxy_extra_args %}
    {{ arg }}{{ ' \\' if not loop.last else '' }}
{% endfor %}

# ── Identity ──────────────────────────────────────────────────────────
# DynamicUser creates a transient uid/gid with no login shell, no
# home directory, and no persistence beyond the service lifetime.
DynamicUser=yes

# ── Capabilities ──────────────────────────────────────────────────────
# Port 53 requires CAP_NET_BIND_SERVICE. Grant only that, nothing else.
# PrivateUsers=yes is intentionally omitted — it creates a user
# namespace that strips real capabilities, breaking port 53 binding.
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
NoNewPrivileges=yes

# ── Filesystem isolation ──────────────────────────────────────────────
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
PrivateDevices=yes
ReadWritePaths=

# ── Kernel isolation ─────────────────────────────────────────────────
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectKernelLogs=yes
ProtectControlGroups=yes
ProtectHostname=yes
ProtectClock=yes
ProtectProc=invisible
ProcSubset=pid

# ── Network isolation ────────────────────────────────────────────────
# AF_INET/AF_INET6 — DNS listening + encrypted upstream connections
# AF_UNIX          — journald logging socket
# AF_NETLINK       — Go runtime enumerates network interfaces at start
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX AF_NETLINK

# ── Syscall filtering ───────────────────────────────────────────────
SystemCallArchitectures=native
SystemCallFilter=@system-service
SystemCallFilter=~@privileged @resources

# ── Logging ─────────────────────────────────────────────────────────
StandardOutput=journal
StandardError=journal
SyslogIdentifier=dnsproxy

# ── Misc hardening ──────────────────────────────────────────────────
RestrictNamespaces=yes
RestrictRealtime=yes
RestrictSUIDSGID=yes
LockPersonality=yes
MemoryDenyWriteExecute=yes
UMask=0077
RemoveIPC=yes

# ── Resource limits ──────────────────────────────────────────────────
LimitNOFILE=65535
LimitNPROC=512

# ── Restart policy ───────────────────────────────────────────────────
# "No disruption": restart immediately on failure, with burst protection.
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
