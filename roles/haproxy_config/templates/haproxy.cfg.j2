{# roles/haproxy/templates/haproxy.cfg.j2 #}
global
    user haproxy
    group haproxy
    maxconn {{ haproxy_maxconn }}
    nbthread {{ haproxy_threads }}
    cpu-map auto:1/1-{{ haproxy_threads }} 0-{{ haproxy_threads - 1 }}

{% if not haproxy_tls_allow_dhe %}
{% set _ciphers = haproxy_tls_ciphers.split(':') | reject('match', '^DHE-') | join(':') %}
{% else %}
{% set _ciphers = haproxy_tls_ciphers %}
{% endif %}
    ssl-default-bind-ciphers {{ _ciphers }}
    ssl-default-bind-ciphersuites {{ haproxy_tls_ciphersuites }}
    ssl-default-bind-options ssl-min-ver {{ haproxy_tls_min_version }} {{ haproxy_tls_options }}
    ssl-default-server-ciphers {{ _ciphers }}
    ssl-default-server-ciphersuites {{ haproxy_tls_ciphersuites }}
    ssl-default-server-options ssl-min-ver {{ haproxy_tls_min_version }} {{ haproxy_tls_options }}

    ca-base /etc/ssl/certs
    crt-base /etc/ssl/private

    log stdout format raw local0 info
    log stdout format raw local1 notice
    log-send-hostname

    stats socket /run/haproxy.sock mode 660 group haproxy level operator expose-fd listeners
    stats timeout 30s

    tune.ssl.default-dh-param {{ haproxy_dh_param_bits }}
    tune.bufsize {{ haproxy_bufsize }}
    tune.maxrewrite {{ haproxy_maxrewrite }}
    tune.ssl.maxrecord {{ haproxy_ssl_maxrecord }}
    tune.ssl.cachesize {{ haproxy_ssl_cachesize }}
{% for line in haproxy_global_extra %}
    {{ line | regex_replace('^\s+', '') }}
{% endfor %}

defaults
    mode http
    timeout connect {{ haproxy_timeout_connect }}
    timeout client {{ haproxy_timeout_client }}
    timeout server {{ haproxy_timeout_server }}
    timeout http-request {{ haproxy_timeout_http_request }}
    timeout http-keep-alive {{ haproxy_timeout_http_keep_alive }}
    timeout queue {{ haproxy_timeout_queue }}
    timeout tunnel {{ haproxy_timeout_tunnel }}

    compression algo gzip
    compression type {{ haproxy_compression_types | join(' ') }}

    log    global
    option httplog
    option log-health-checks
    option dontlognull

    option http-server-close
    option redispatch
    option splice-auto
{% if haproxy_option_forwardfor %}
    option forwardfor
{% endif %}
    retries 3

    default-server check inter 10s fall 3 rise 2

    errorfile 400 {{ haproxy_base_errors_dir }}/400.http
    errorfile 403 {{ haproxy_base_errors_dir }}/403.http
    errorfile 404 {{ haproxy_base_errors_dir }}/404.http
    errorfile 408 {{ haproxy_base_errors_dir }}/408.http
    errorfile 429 {{ haproxy_base_errors_dir }}/429.http
    errorfile 500 {{ haproxy_base_errors_dir }}/500.http
    errorfile 502 {{ haproxy_base_errors_dir }}/502.http
    errorfile 503 {{ haproxy_base_errors_dir }}/503.http
    errorfile 504 {{ haproxy_base_errors_dir }}/504.http
{% for line in haproxy_defaults_extra %}
    {{ line | regex_replace('^\s+', '') }}
{% endfor %}

# ── Stats frontend ──────────────────────────────────────────────────
frontend stats
    bind 127.0.0.1:{{ haproxy_stats_port }}
    stats enable
    stats uri /stats
    stats refresh 30s
{% if haproxy_stats_auth_password %}
    stats auth {{ haproxy_stats_auth_user }}:{{ haproxy_stats_auth_password }}
    stats admin if TRUE
{% endif %}
    http-request use-service prometheus-exporter if { path /metrics }

# ── Main web frontend ──────────────────────────────────────────────
frontend web
    bind *:80
    bind *:443 ssl crt {{ haproxy_base_certs_dir }}/ alpn h2,http/1.1

    http-request set-var(txn.req_hdrs) req.hdrs
{% if haproxy_coraza_enabled %}
    log-format "${HAPROXY_HTTP_LOG_FMT} spoa-error:\ %[var(txn.coraza.error)]\ waf-hit:\ %[var(txn.coraza.fail)] req_hdrs:%{+Q}[var(txn.req_hdrs)] resp_hdrs:%{+Q}[var(txn.resp_hdrs)]"
{% else %}
    log-format "${HAPROXY_HTTP_LOG_FMT} req_hdrs:%{+Q}[var(txn.req_hdrs)] resp_hdrs:%{+Q}[var(txn.resp_hdrs)]"
{% endif %}

{% if haproxy_cloudflare_enabled %}
    # --- Cloudflare enforcement ---
    acl is_cloudflare src -f {{ haproxy_cloudflare_ips_file }}
    acl has_cf_ray hdr(CF-Ray) -m found
    acl has_cf_visitor hdr(CF-Visitor) -m found
    acl has_cf_connecting_ip hdr(CF-Connecting-IP) -m found
{% if haproxy_cloudflare_bypass_hosts %}
{% for host in haproxy_cloudflare_bypass_hosts %}
    acl cf_bypass hdr(host) -i {{ host }}
{% endfor %}
    http-request capture src len 40 if !is_cloudflare
    http-request silent-drop unless cf_bypass || is_cloudflare has_cf_ray has_cf_visitor has_cf_connecting_ip
{% else %}
    http-request capture src len 40 if !is_cloudflare
    http-request silent-drop unless is_cloudflare has_cf_ray has_cf_visitor has_cf_connecting_ip
{% endif %}
    http-request set-src req.hdr(CF-Connecting-IP) if has_cf_connecting_ip
{% endif %}

{% if haproxy_cors_allowed_domains %}
    acl allowed_origin_exact hdr(origin) -i -m str -f {{ haproxy_base_config_dir }}/allowed_domains.txt
{% endif %}
{% if haproxy_cors_subdomain_patterns %}
{% for pattern in haproxy_cors_subdomain_patterns %}
    acl allowed_origin_subdomain hdr(origin) -i -m end .{{ pattern }}
{% endfor %}
{% endif %}
{% if haproxy_cors_allowed_domains or haproxy_cors_subdomain_patterns %}
    acl has_valid_origin hdr(origin) -m found
{% if haproxy_cors_allowed_domains and haproxy_cors_subdomain_patterns %}
    http-request set-var(txn.origin) hdr(origin) if has_valid_origin allowed_origin_exact or has_valid_origin allowed_origin_subdomain
{% elif haproxy_cors_allowed_domains %}
    http-request set-var(txn.origin) hdr(origin) if has_valid_origin allowed_origin_exact
{% else %}
    http-request set-var(txn.origin) hdr(origin) if has_valid_origin allowed_origin_subdomain
{% endif %}

{% endif %}

    unique-id-format %[uuid()]
    unique-id-header X-Unique-ID

{% if haproxy_rate_limiting_enabled %}
    # --- Rate limiting ---
    stick-table type ip size 100k expire 30s store http_req_rate({{ haproxy_rate_limit_http_req_period }}s),http_err_rate({{ haproxy_rate_limit_http_req_period }}s),conn_rate({{ haproxy_rate_limit_conn_period }}s),conn_cur,gpc0,gpc0_rate({{ haproxy_rate_limit_api_period }}s)
    http-request track-sc0 src
    http-request return status 429 if { sc_http_req_rate(0) gt {{ haproxy_rate_limit_http_req_count }} }
    http-request return status 429 if { sc_conn_rate(0) gt {{ haproxy_rate_limit_conn_count }} }
    http-request return status 429 if { sc_conn_cur(0) gt {{ haproxy_rate_limit_concurrent }} }
    http-request sc-inc-gpc0(0) if { path_beg {{ haproxy_rate_limit_api_path_prefix }} }
    http-request return status 429 if { sc_gpc0_rate(0) gt {{ haproxy_rate_limit_api_count }} } { path_beg {{ haproxy_rate_limit_api_path_prefix }} }
{% endif %}

{% if haproxy_blocked_extensions %}
{% for ext in haproxy_blocked_extensions %}
    http-request return status 403 if { path_end -i .{{ ext }} }
{% endfor %}
{% endif %}
{% if haproxy_blocked_user_agents %}
    http-request return status 403 if { hdr(user-agent) -i -m sub ({{ haproxy_blocked_user_agents | join('|') }}) }
{% endif %}

{% if haproxy_honeypot_enabled and haproxy_honeypot_fields %}
{% for field in haproxy_honeypot_fields %}
    http-request set-var(txn.req_body_param_{{ field }}) req.body_param({{ field }})
    http-request return status 400 if { var(txn.req_body_param_{{ field }}) -m len gt 0 }
{% endfor %}
{% endif %}

{% for line in haproxy_frontend_extra_acls %}
    {{ line | regex_replace('^\s+', '') }}
{% endfor %}

    filter compression
{% if haproxy_coraza_enabled %}
    filter spoe engine coraza config {{ haproxy_base_config_dir }}/coraza.cfg
{% endif %}
{% if haproxy_coraza_enabled %}
    http-request set-var(txn.coraza.app) str(app)
    http-request return status 403 if { var(txn.coraza.fail) -m int eq 1 }
    http-response return status 403 if { var(txn.coraza.fail) -m int eq 1 }
    http-request return status 503 if { var(txn.coraza.error) -m int gt 0 }
    http-response return status 503 if { var(txn.coraza.error) -m int gt 0 }
{% endif %}

{% if haproxy_cdn_domains %}
{% for domain in haproxy_cdn_domains %}
    acl cdn hdr(host) -i {{ domain }}
{% endfor %}
{% endif %}
    acl is_options method OPTIONS
{% if haproxy_cdn_domains %}
    http-request return status 204 if is_options { var(txn.origin) -m found } or is_options cdn
{% elif haproxy_allow_options_all_origins %}
    http-request return status 204 if is_options { var(txn.origin) -m found }
{% endif %}

    http-request set-var(txn.path) path

    redirect scheme https code 301 if !{ ssl_fc }

{% if haproxy_cache_control_enabled %}
    # --- Cache-Control (differentiated by content type) ---
    acl is_static_asset var(txn.path) -m end {{ haproxy_static_extensions | map('regex_replace', '^', '.') | join(' ') }}
    acl is_hashed_asset var(txn.path) -m reg -i {{ haproxy_hashed_asset_regex }}
    acl has_cache_control res.hdr(Cache-Control) -m found

    http-response set-header Cache-Control "{{ haproxy_cache_control_hashed }}" if is_hashed_asset
    http-response set-header Cache-Control "{{ haproxy_cache_control_static }}" if is_static_asset !is_hashed_asset
    http-response set-header Cache-Control "{{ haproxy_cache_control_default }}" if !is_static_asset !has_cache_control
{% endif %}

{% if haproxy_security_headers_enabled %}
    # --- Security headers (configurable, backend-respecting) ---
{% if haproxy_alt_svc_enabled %}
    http-response set-header Alt-Svc "h3=\":443\"; ma=86400"
{% endif %}
    http-response set-header Content-Security-Policy "{{ haproxy_csp }}" unless { res.hdr(Content-Security-Policy) -m found }
{% if haproxy_coep %}
    http-response set-header Cross-Origin-Embedder-Policy "{{ haproxy_coep }}" unless { res.hdr(Cross-Origin-Embedder-Policy) -m found }
{% endif %}
{% if haproxy_coop %}
    http-response set-header Cross-Origin-Opener-Policy "{{ haproxy_coop }}" unless { res.hdr(Cross-Origin-Opener-Policy) -m found }
{% endif %}
{% if haproxy_corp %}
    http-response set-header Cross-Origin-Resource-Policy "{{ haproxy_corp }}" unless { res.hdr(Cross-Origin-Resource-Policy) -m found }
{% endif %}
    http-response set-header Permissions-Policy "{{ haproxy_permissions_policy }}" unless { res.hdr(Permissions-Policy) -m found }
    http-response set-header Referrer-Policy "{{ haproxy_referrer_policy }}" unless { res.hdr(Referrer-Policy) -m found }
    http-response set-header Strict-Transport-Security "max-age={{ haproxy_hsts_max_age }}{% if haproxy_hsts_include_subdomains %}; includeSubDomains{% endif %}{% if haproxy_hsts_preload %}; preload{% endif %}" unless { res.hdr(Strict-Transport-Security) -m found }
    http-response set-header X-Frame-Options "{{ haproxy_x_frame_options }}" unless { res.hdr(X-Frame-Options) -m found }
    http-response set-header X-XSS-Protection "{{ haproxy_x_xss_protection }}" unless { res.hdr(X-XSS-Protection) -m found }

    # --- Hardcoded headers (universally safe) ---
    http-response set-header X-Content-Type-Options nosniff
    http-response set-header X-DNS-Prefetch-Control off
    http-response set-header X-Download-Options noopen
    http-response set-header X-Permitted-Cross-Domain-Policies none
    http-response del-header Server
    http-response del-header X-Powered-By
{% endif %}

{% if haproxy_cors_allowed_domains or haproxy_cors_subdomain_patterns %}
    # --- CORS (only if backend doesn't set its own) ---
    acl has_cors_origin res.hdr(Access-Control-Allow-Origin) -m found
    http-response set-header Access-Control-Allow-Origin %[var(txn.origin)] if { var(txn.origin) -m found } !has_cors_origin
    http-response set-header Access-Control-Allow-Methods "{{ haproxy_cors_allowed_methods }}" if { var(txn.origin) -m found } !has_cors_origin
    http-response set-header Access-Control-Allow-Headers "{{ haproxy_cors_allowed_headers }}" if { var(txn.origin) -m found } !has_cors_origin
    http-response set-header Access-Control-Expose-Headers "{{ haproxy_cors_expose_headers }}" if { var(txn.origin) -m found } !has_cors_origin
{% if haproxy_cors_allow_credentials %}
    http-response set-header Access-Control-Allow-Credentials "true" if { var(txn.origin) -m found } !has_cors_origin
{% endif %}
    http-response set-header Access-Control-Max-Age "{{ haproxy_cors_max_age }}" if { var(txn.origin) -m found } !has_cors_origin
    http-response set-header Vary "Origin"
{% endif %}

{% for line in haproxy_frontend_extra_rules %}
    {{ line | regex_replace('^\s+', '') }}
{% endfor %}

    # --- Routing ---
{% for route in haproxy_routes %}
{% if route.match.host is defined %}
    acl route_{{ loop.index }} hdr(host) -i {{ route.match.host }}
{% elif route.match.host_suffix is defined %}
    acl route_{{ loop.index }} hdr(host) -i -m end .{{ route.match.host_suffix }}
{% elif route.match.path_prefix is defined %}
    acl route_{{ loop.index }} path_beg {{ route.match.path_prefix }}
{% endif %}
    use_backend {{ route.backend }} if route_{{ loop.index }}
{% endfor %}

    default_backend not_found

# ── Listen sections ─────────────────────────────────────────────────
{% for section in haproxy_listen_sections %}
listen {{ section.name }}
    bind {{ section.bind }}
    mode {{ section.mode | default('tcp') }}
{% if section.mode | default('tcp') == 'tcp' %}
    option tcplog
{% else %}
    option httplog
{% endif %}
    option log-health-checks
{% if section.rate_limit is defined %}

    stick-table type ip size 10k expire 30s store conn_rate(10s),conn_cur,gpc0,gpc0_rate(60s)
    tcp-request connection track-sc0 src
    tcp-request connection reject if { sc_conn_rate(0) gt {{ section.rate_limit.conn_rate | default(10) }} }
    tcp-request connection reject if { sc_conn_cur(0) gt {{ section.rate_limit.conn_cur | default(5) }} }
    tcp-request connection sc-inc-gpc0(0)
    tcp-request connection reject if { sc_gpc0_rate(0) gt {{ section.rate_limit.gpc0_rate | default(100) }} }
{% endif %}
{% for line in section.options | default([]) %}
    {{ line | regex_replace('^\s+', '') }}
{% endfor %}
{% for server in section.servers %}
    server {{ server.name }} {{ server.address }}:{{ server.port }} check inter 3000 rise 1 fall 3
{% endfor %}

{% endfor %}
# ── Backends ────────────────────────────────────────────────────────
{% for backend in haproxy_backends %}
backend {{ backend.name }}
{% if backend.mode | default('http') != 'http' %}
    mode {{ backend.mode }}
{% endif %}
{% if backend.balance is defined %}
    balance {{ backend.balance }}
{% endif %}
{% if backend.health_check is defined %}
    option httpchk {{ backend.health_check }}
{% endif %}
{% for line in backend.options | default([]) %}
    {{ line | regex_replace('^\s+', '') }}
{% endfor %}
{% for server in backend.servers %}
    server {{ server.name }} {{ server.address }}:{{ server.port }} check inter 3000 rise 1 fall 3
{% endfor %}

{% endfor %}
backend not_found
    http-request return status 404

{% if haproxy_coraza_enabled %}
backend coraza-spoa
    mode tcp
    server s1 {{ haproxy_coraza_spoa_addr }}:{{ haproxy_coraza_spoa_port }} check inter 3000 rise 1 fall 3
{% endif %}
