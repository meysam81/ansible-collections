# {{ ansible_managed }}
[Unit]
Description=Ory Oathkeeper Access Control Proxy
Documentation=https://www.ory.sh/oathkeeper/docs/
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=500
StartLimitBurst=5

[Service]
Type=simple

Environment="OATHKEEPER_ARGS=--config /etc/oathkeeper/config.yml"
ExecStart={{ oathkeeper_exec_cmd }} $OATHKEEPER_ARGS

# ── Identity ──────────────────────────────────────────────────────────
User=oathkeeper
Group=oathkeeper

# ── Capabilities ──────────────────────────────────────────────────────
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
NoNewPrivileges=yes

# ── Filesystem isolation ──────────────────────────────────────────────
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
PrivateDevices=yes
ReadWritePaths=
RuntimeDirectory=oathkeeper
RuntimeDirectoryMode=0755

# ── Kernel isolation ─────────────────────────────────────────────────
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectKernelLogs=yes
ProtectControlGroups=yes
ProtectHostname=yes
ProtectClock=yes
ProtectProc=invisible
ProcSubset=pid

# ── Network isolation ────────────────────────────────────────────────
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX AF_NETLINK

# ── Syscall filtering ───────────────────────────────────────────────
SystemCallArchitectures=native
SystemCallFilter=@system-service
SystemCallFilter=~@privileged @resources

# ── Logging ─────────────────────────────────────────────────────────
StandardOutput=journal
StandardError=journal
SyslogIdentifier=oathkeeper

# ── Misc hardening ──────────────────────────────────────────────────
RestrictNamespaces=yes
RestrictRealtime=yes
RestrictSUIDSGID=yes
LockPersonality=yes
MemoryDenyWriteExecute=yes
RemoveIPC=yes
UMask=0077

# ── Resource limits ──────────────────────────────────────────────────
LimitNOFILE=65535
LimitNPROC=4096
LimitCORE=0
CPUQuota=80%
Nice=10

# ── Restart policy ───────────────────────────────────────────────────
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target
