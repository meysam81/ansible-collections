# {{ ansible_managed }}
# Minimal bootstrap config — ensures haproxy can start before a full
# configuration is deployed (e.g. via the haproxy_config role).
global
    log stdout format raw local0 info
    maxconn 256
    user haproxy
    group haproxy

defaults
    log     global
    mode    http
    option  httplog
    timeout connect 5s
    timeout client  30s
    timeout server  30s

frontend health
    bind *:8405
    http-request return status 200 content-type text/plain string "OK\n"
