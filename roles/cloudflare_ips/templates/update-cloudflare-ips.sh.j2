#!/bin/bash
# {{ ansible_managed }}
set -euo pipefail

CF_IPV4_URL="https://www.cloudflare.com/ips-v4"
CF_IPV6_URL="https://www.cloudflare.com/ips-v6"
IP_FILE="{{ cloudflare_ips_file }}"
HAPROXY_CFG="{{ haproxy_config_dir }}/haproxy.cfg"

touch "$IP_FILE"

ip_addresses=$(mktemp)
trap 'rm -f "$ip_addresses"' EXIT

curl -f -s --retry 3 --retry-delay 5 "$CF_IPV4_URL" >> "$ip_addresses"
echo >> "$ip_addresses"
curl -f -s --retry 3 --retry-delay 5 "$CF_IPV6_URL" >> "$ip_addresses"
echo >> "$ip_addresses"

chown haproxy:haproxy "$ip_addresses"
chmod 644 "$ip_addresses"

if ! cmp -s "$ip_addresses" "$IP_FILE"; then
    cp "$IP_FILE" "${IP_FILE}.bak"

    mv "$ip_addresses" "$IP_FILE"

    if haproxy -c -f "$HAPROXY_CFG"; then
        systemctl reload haproxy
        echo "Cloudflare IPs updated and HAProxy reloaded"
    else
        mv "${IP_FILE}.bak" "$IP_FILE"
        echo "HAProxy config test failed, restored previous IPs"
        exit 1
    fi
else
    echo "Cloudflare IPs unchanged"
fi
