#!/usr/bin/env bash
# {{ ansible_managed }}
set -uo pipefail

exit_code=0
DIR="{{ blocklist_updater_dir }}"
{% if blocklist_updater_allowlist %}
ALLOWLIST="${DIR}/.allowlist"
{% endif %}

{% for feed in blocklist_updater_feeds %}
# ── {{ feed.name }} ──
DEST="${DIR}/{{ feed.name }}.txt"
TMPFILE="${DEST}.tmp"

if curl -sS --max-time 30 "{{ feed.url }}" | {{ feed.filter }} > "$TMPFILE"; then
  if [ ! -s "$TMPFILE" ]; then
    echo "WARNING: {{ feed.name }} returned empty output, keeping existing file" >&2
    rm -f "$TMPFILE"
    exit_code=1
  else
{% if blocklist_updater_reject_bogons %}
    # Strip private/reserved IP ranges (transparent for domain feeds)
    grep -vE '^(10\.|172\.(1[6-9]|2[0-9]|3[01])\.|192\.168\.|127\.|0\.|100\.(6[4-9]|[7-9][0-9]|1[0-2][0-7])\.|169\.254\.|224\.|240\.)' "$TMPFILE" > "${TMPFILE}.clean" || true
    mv "${TMPFILE}.clean" "$TMPFILE"
{% endif %}
{% if blocklist_updater_allowlist %}
    # Apply allowlist (exact whole-line match)
    grep -vFxf "$ALLOWLIST" "$TMPFILE" > "${TMPFILE}.filtered" || true
    mv "${TMPFILE}.filtered" "$TMPFILE"
{% endif %}

    NEW_COUNT=$(wc -l < "$TMPFILE")
    OLD_COUNT=0
    if [ -f "$DEST" ]; then
      OLD_COUNT=$(wc -l < "$DEST")
    fi

    echo "INFO: {{ feed.name }}: ${NEW_COUNT} entries (was ${OLD_COUNT})"

    # Shrinkage detection: reject if count dropped >50%
    if [ "$OLD_COUNT" -gt 0 ] && [ "$NEW_COUNT" -lt $((OLD_COUNT / 2)) ]; then
      echo "WARNING: {{ feed.name }} shrank by >50% (${OLD_COUNT} -> ${NEW_COUNT}), keeping existing file" >&2
      rm -f "$TMPFILE"
      exit_code=1
    else
      mv "$TMPFILE" "$DEST"
    fi
  fi
else
  echo "ERROR: Failed to fetch {{ feed.name }}" >&2
  rm -f "$TMPFILE"
  exit_code=1
fi

{% endfor %}
# Log total entry count across all blocklists
TOTAL=$(cat "${DIR}"/*.txt 2>/dev/null | wc -l)
echo "INFO: Total blocklist entries: ${TOTAL}"
{% if blocklist_updater_signal_process %}

pkill -HUP {{ blocklist_updater_signal_process }} || true
{% endif %}

exit $exit_code
