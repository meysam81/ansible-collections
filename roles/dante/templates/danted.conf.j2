# {{ ansible_managed }}

# ── Logging ────────────────────────────────────────────────────────────
errorlog: {{ dante_error_log }}
logoutput: {{ dante_log_file }}

# ── Network ────────────────────────────────────────────────────────────
{% for addr in dante_listen_addresses %}
internal: {{ addr }} port = {{ dante_listen_port }}
{% endfor %}
external: {{ dante_external_interface }}

# ── Users ──────────────────────────────────────────────────────────────
user.privileged: root
user.notprivileged: {{ dante_user }}

# ── Authentication ─────────────────────────────────────────────────────
# No password auth — WireGuard tunnel provides implicit authentication.
# Source IP ACLs in client rules below restrict access to tunnel subnet.
socksmethod: none
clientmethod: none

# ── Timeouts ───────────────────────────────────────────────────────────
timeout.negotiate: {{ dante_timeout_negotiate }}
timeout.io: {{ dante_timeout_io }}
timeout.connect: {{ dante_timeout_connect }}

# ── Log parts (computed once) ─────────────────────────────────────────
{% set _lp = [] %}
{% if dante_log_connect %}{% if _lp.append('connect') %}{% endif %}{% endif %}
{% if dante_log_disconnect %}{% if _lp.append('disconnect') %}{% endif %}{% endif %}
{% if dante_log_error %}{% if _lp.append('error') %}{% endif %}{% endif %}

# ── Client Rules (source IP filtering) ────────────────────────────────
# First match wins. Allow tunnel sources, block everything else.
{% for src in dante_allowed_sources %}
client pass {
    from: {{ src }} to: {{ '::/0' if ':' in src else '0.0.0.0/0' }}
{% if _lp %}
    log: {{ _lp | join(' ') }}
{% endif %}
}
{% endfor %}

client block {
    from: 0.0.0.0/0 to: 0.0.0.0/0
    log: connect error
}

client block {
    from: ::/0 to: ::/0
    log: connect error
}

# ── SOCKS Rules (destination filtering) ───────────────────────────────
# First match wins. Blocks evaluated first, then per-port allows.
# Rules cover both address families to support dual-stack clients.
{% set _blocked = [('127.0.0.0/8', 'IPv4 loopback'), ('::1/128', 'IPv6 loopback')] %}
{% if dante_block_private_destinations %}
{% set _ = _blocked.extend([
    ('10.0.0.0/8', 'RFC1918'),
    ('172.16.0.0/12', 'RFC1918'),
    ('192.168.0.0/16', 'RFC1918'),
    ('169.254.0.0/16', 'IPv4 link-local'),
    ('fc00::/7', 'ULA'),
    ('fe80::/10', 'IPv6 link-local'),
]) %}
{% endif %}

{% for dest, label in _blocked %}
# Block {{ label }}
{% for from_wc in ['0.0.0.0/0', '::/0'] %}
socks block {
    from: {{ from_wc }} to: {{ dest }}
    command: connect
    log: connect error
}
{% endfor %}

{% endfor %}
# Per-port allow rules (all address-family combinations)
{% for port in dante_allowed_ports %}
{% for from_wc in ['0.0.0.0/0', '::/0'] %}
{% for to_wc in ['0.0.0.0/0', '::/0'] %}
socks pass {
    from: {{ from_wc }} to: {{ to_wc }} port = {{ port }}
    command: connect
    protocol: tcp
{% if _lp %}
    log: {{ _lp | join(' ') }}
{% endif %}
}
{% endfor %}
{% endfor %}

{% endfor %}
# Default deny
{% for from_wc in ['0.0.0.0/0', '::/0'] %}
{% for to_wc in ['0.0.0.0/0', '::/0'] %}
socks block {
    from: {{ from_wc }} to: {{ to_wc }}
    log: connect error
}
{% endfor %}
{% endfor %}
