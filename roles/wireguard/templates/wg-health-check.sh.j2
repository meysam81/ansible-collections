#!/usr/bin/env bash
# {{ ansible_managed }}
#
# WireGuard tunnel health check — verifies egress IP matches expected value.
# Restarts wg-quick if the check fails. Stops restarting after 3 consecutive
# failures to avoid a restart storm.

set -euo pipefail

INTERFACE="{{ wireguard_interface }}"
EXPECTED_IP="{{ wireguard_health_check_expected_ip }}"
STATE_FILE="/run/wg-health-check.failures"

# Read consecutive failure count
FAILURES=0
if [ -f "$STATE_FILE" ]; then
  FAILURES=$(cat "$STATE_FILE" 2>/dev/null || echo 0)
fi

MAX_FAILURES=3

if [ "$FAILURES" -ge "$MAX_FAILURES" ]; then
  echo "SKIP: $FAILURES consecutive failures, not restarting (manual intervention required)" >&2
  exit 1
fi

CURRENT_IP=$(curl -s --max-time 10 https://ifconfig.me || true)

if [ -z "$CURRENT_IP" ]; then
  FAILURES=$((FAILURES + 1))
  echo "$FAILURES" > "$STATE_FILE"
  echo "ERROR: Could not determine current egress IP (failure $FAILURES/$MAX_FAILURES)" >&2
  systemctl restart "wg-quick@${INTERFACE}"
  exit 1
fi

if [ "$CURRENT_IP" != "$EXPECTED_IP" ]; then
  FAILURES=$((FAILURES + 1))
  echo "$FAILURES" > "$STATE_FILE"
  echo "MISMATCH: egress IP is ${CURRENT_IP}, expected ${EXPECTED_IP} (failure $FAILURES/$MAX_FAILURES)" >&2
  systemctl restart "wg-quick@${INTERFACE}"
  exit 1
fi

{% if wireguard_health_check_expected_ipv6 %}
# IPv6 egress check
EXPECTED_IPV6="{{ wireguard_health_check_expected_ipv6 }}"
CURRENT_IPV6=$(curl -6 -s --max-time 10 https://ifconfig.me || true)

if [ -z "$CURRENT_IPV6" ]; then
  FAILURES=$((FAILURES + 1))
  echo "$FAILURES" > "$STATE_FILE"
  echo "ERROR: Could not determine current IPv6 egress IP (failure $FAILURES/$MAX_FAILURES)" >&2
  systemctl restart "wg-quick@${INTERFACE}"
  exit 1
fi

if [ "$CURRENT_IPV6" != "$EXPECTED_IPV6" ]; then
  FAILURES=$((FAILURES + 1))
  echo "$FAILURES" > "$STATE_FILE"
  echo "MISMATCH: IPv6 egress IP is ${CURRENT_IPV6}, expected ${EXPECTED_IPV6} (failure $FAILURES/$MAX_FAILURES)" >&2
  systemctl restart "wg-quick@${INTERFACE}"
  exit 1
fi
{% endif %}

# Success — reset failure counter
if [ "$FAILURES" -gt 0 ]; then
  rm -f "$STATE_FILE"
fi
echo "OK: egress IP is ${CURRENT_IP}"
