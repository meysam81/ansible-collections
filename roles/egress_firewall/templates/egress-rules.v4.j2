# {{ ansible_managed }}
*filter
:EGRESS-WG-INPUT - [0:0]
:EGRESS-WG-FORWARD - [0:0]
{% if egress_firewall_socks_enabled and (egress_firewall_socks_allowed_ports | length > 0 or egress_firewall_socks_block_private) %}
:EGRESS-WG-OUTPUT - [0:0]
{% endif %}
-F EGRESS-WG-INPUT
-F EGRESS-WG-FORWARD
-A EGRESS-WG-INPUT -m state --state RELATED,ESTABLISHED -j ACCEPT
-A EGRESS-WG-INPUT -p tcp --dport {{ egress_firewall_proxy_port }} -j ACCEPT
{% if egress_firewall_socks_enabled %}
-A EGRESS-WG-INPUT -p tcp --dport {{ egress_firewall_socks_port }} -j ACCEPT
{% endif %}
-A EGRESS-WG-INPUT -p tcp --dport {{ egress_firewall_dns_port }} -j ACCEPT
-A EGRESS-WG-INPUT -p udp --dport {{ egress_firewall_dns_port }} -j ACCEPT
{% for exc in egress_firewall_input_exceptions %}
# {{ exc.comment | default('input exception') }}
-A EGRESS-WG-INPUT -p {{ exc.proto }} --dport {{ exc.dport }} -j ACCEPT
{% endfor %}
-A EGRESS-WG-INPUT -j DROP
{% for exc in egress_firewall_forward_exceptions %}
# {{ exc.comment | default('forward exception') }}
-A EGRESS-WG-FORWARD -p {{ exc.proto }}{% if exc.dest is defined %} -d {{ exc.dest }}{% endif %} --dport {{ exc.dport }} -j ACCEPT
{% endfor %}
-A EGRESS-WG-FORWARD -j DROP
{% if egress_firewall_socks_enabled and (egress_firewall_socks_allowed_ports | length > 0 or egress_firewall_socks_block_private) %}
-F EGRESS-WG-OUTPUT
{% if egress_firewall_socks_block_private %}
# Allow DNS to local resolver before blocking private destinations
-A EGRESS-WG-OUTPUT -m owner --uid-owner {{ egress_firewall_socks_user }} -p udp --dport {{ egress_firewall_dns_port }} -j ACCEPT
-A EGRESS-WG-OUTPUT -m owner --uid-owner {{ egress_firewall_socks_user }} -p tcp --dport {{ egress_firewall_dns_port }} -j ACCEPT
# Fast-path established connections before block rules
-A EGRESS-WG-OUTPUT -m owner --uid-owner {{ egress_firewall_socks_user }} -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT
# Block SOCKS user from reaching private destinations
-A EGRESS-WG-OUTPUT -m owner --uid-owner {{ egress_firewall_socks_user }} -d 127.0.0.0/8 -j DROP
-A EGRESS-WG-OUTPUT -m owner --uid-owner {{ egress_firewall_socks_user }} -d 10.0.0.0/8 -j DROP
-A EGRESS-WG-OUTPUT -m owner --uid-owner {{ egress_firewall_socks_user }} -d 172.16.0.0/12 -j DROP
-A EGRESS-WG-OUTPUT -m owner --uid-owner {{ egress_firewall_socks_user }} -d 192.168.0.0/16 -j DROP
-A EGRESS-WG-OUTPUT -m owner --uid-owner {{ egress_firewall_socks_user }} -d 169.254.0.0/16 -j DROP
{% endif %}
{% if egress_firewall_socks_allowed_ports | length > 0 %}
# SOCKS user port allowlist
{% for port in egress_firewall_socks_allowed_ports %}
-A EGRESS-WG-OUTPUT -m owner --uid-owner {{ egress_firewall_socks_user }} -p tcp --dport {{ port }} -j ACCEPT
{% endfor %}
-A EGRESS-WG-OUTPUT -m owner --uid-owner {{ egress_firewall_socks_user }} -j DROP
{% endif %}
{% endif %}
COMMIT

*nat
:EGRESS-WG-NAT - [0:0]
-F EGRESS-WG-NAT
# Squid's own outbound connections
-A EGRESS-WG-NAT -m owner --uid-owner {{ egress_firewall_proxy_user }} -j MASQUERADE
{% if egress_firewall_socks_enabled %}
# SOCKS proxy outbound connections
-A EGRESS-WG-NAT -m owner --uid-owner {{ egress_firewall_socks_user }} -j MASQUERADE
{% endif %}
{% for exc in egress_firewall_forward_exceptions %}
# {{ exc.comment | default('forward exception') }}
-A EGRESS-WG-NAT -p {{ exc.proto }}{% if exc.dest is defined %} -d {{ exc.dest }}{% endif %} --dport {{ exc.dport }} -j MASQUERADE
{% endfor %}
COMMIT
