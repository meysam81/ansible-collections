# {{ ansible_managed }}
[Unit]
Description=Egress firewall enforcement (WireGuard → Squid)
Before=wg-quick@{{ egress_firewall_tunnel_interface }}.service
After=network-pre.target
Wants=network-pre.target

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/bin/bash -c 'iptables-restore --noflush < /etc/iptables/egress-rules.v4{% if egress_firewall_ipv6_enabled %} && ip6tables-restore --noflush < /etc/iptables/egress-rules.v6{% endif %} && /usr/local/bin/egress-jumps.sh'

[Install]
WantedBy=multi-user.target
